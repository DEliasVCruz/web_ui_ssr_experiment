{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"types": ["bun-types"],
		"lib": ["ES2022", "DOM"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"paths": {
			"@/*": ["./src/*"],
			"styled-system/*": ["./styled-system/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "build"]
}
