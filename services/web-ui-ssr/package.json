{
	"name": "@web-ui-poc/web-ui-ssr",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"prepare": "panda codegen --clean",
		"dev": "NODE_ENV=development NODE_OPTIONS=--experimental-vm-modules tsx src/index.ts",
		"build": "rsbuild build",
		"start": "bun dist/server/index.js",
		"typecheck": "tsc --noEmit",
		"lint:eslint": "eslint src/",
		"panda:codegen": "panda codegen --clean"
	},
	"dependencies": {
		"@connectrpc/connect": "^2.1.1",
		"@connectrpc/connect-node": "^2.1.1",
		"@connectrpc/connect-query-core": "^2.0.1",
		"@connectrpc/connect-web": "^2.1.1",
		"@tanstack/solid-query": "^5.62.7",
		"@tanstack/solid-router": "^1.168.24",
		"@tanstack/solid-router-ssr-query": "^1.166.12",
		"@web-ui-poc/rpc": "workspace:*",
		"hono": "^4.6.14",
		"solid-js": "^1.9.5"
	},
	"devDependencies": {
		"@hono/node-server": "^1.13.8",
		"@pandacss/dev": "^1.10.0",
		"@rsbuild/core": "^2.0.1",
		"@rsbuild/plugin-babel": "^1.1.2",
		"@rsbuild/plugin-solid": "^1.1.1",
		"@tanstack/router-plugin": "^1.167.27",
		"bun-types": "^1.3.13",
		"postcss": "^8.5.10",
		"tsx": "^4.19.4",
		"typescript": "^5.7.2"
	}
}
